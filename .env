# ============================================================
#  Coffee Oracle Bot — Конфигурация
# ============================================================
#  Скопируйте этот файл в .env и заполните значения:
#  cp .env.example .env
# ============================================================


# ------------------------------------------------------------
#  Telegram-бот (ОБЯЗАТЕЛЬНО)
# ------------------------------------------------------------

# Токен Telegram-бота, полученный от @BotFather
BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------
#  MAX-бот (ОПЦИОНАЛЬНО)
# ------------------------------------------------------------

# Токен бота в мессенджере MAX (platform-api.max.ru)
# Если не задан — MAX-бот не запускается, работает только Telegram
# Получить токен: MAX для партнёров → Интеграция → Получить токен
MAX_BOT_TOKEN=


# ------------------------------------------------------------
#  Админ-панель (ОБЯЗАТЕЛЬНО)
# ------------------------------------------------------------

# Логин и пароль для входа в веб-админку (HTTP Basic Auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_strong_password_here

# Порт админ-панели (по умолчанию: 8000)
ADMIN_PORT=8000

# Секретный ключ приложения (используется для безопасности сессий)
SECRET_KEY=change-this-to-random-string-at-least-32-chars


# ------------------------------------------------------------
#  OpenAI / LLM (ОБЯЗАТЕЛЬНО — хотя бы один ключ)
# ------------------------------------------------------------

# API-ключ OpenAI (обязательно, если не задан LITELLM_API_KEY)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Или используйте LITELLM_API_KEY (приоритет над OPENAI_API_KEY)
# LITELLM_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Модель для анализа изображений (по умолчанию: gpt-4o-mini)
# Рекомендуемые: gpt-4o-mini, gpt-4o, gpt-4.1
LITELLM_MODEL=gpt-4o-mini

# Кастомный URL API (для прокси, Azure, локальных моделей)
# Оставьте пустым для стандартного API OpenAI
# LITELLM_API_BASE=https://your-proxy.example.com/v1

# Версия API (только для Azure OpenAI)
# LITELLM_API_VERSION=2024-02-15-preview

# Таймаут запросов к LLM в секундах (по умолчанию: 30)
LITELLM_TIMEOUT=30

# Максимальное количество токенов в ответе (по умолчанию: 1500)
LITELLM_MAX_TOKENS=1500

# Температура генерации: 0.0 = детерминировано, 2.0 = максимально креативно
# Рекомендуемое значение для предсказаний: 0.7–0.9 (по умолчанию: 0.8)
LITELLM_TEMPERATURE=0.8


# ------------------------------------------------------------
#  База данных (ОПЦИОНАЛЬНО)
# ------------------------------------------------------------

# Имя файла SQLite базы данных (по умолчанию: coffee_oracle.db)
# Файл создаётся автоматически в папке data/
DB_NAME=coffee_oracle.db