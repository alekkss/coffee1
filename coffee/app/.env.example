BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
DOMAIN=localhost
ADMIN_USERNAME=admin
ADMIN_PASSWORD=secret_pass
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars
DB_NAME=coffee_oracle.db

# Cookie security (default: true; set to false for local HTTP development)
SECURE_COOKIES=true

# LiteLLM Configuration
LITELLM_MODEL=openai/gpt-5.1
LITELLM_API_KEY=sk-proj-...
LITELLM_API_BASE=https://api.1bitai.ru/v1
# LITELLM_API_VERSION=2023-12-01-preview
LITELLM_TIMEOUT=30
LITELLM_MAX_TOKENS=1500
LITELLM_TEMPERATURE=0.8

Fallback model (optional) - used if primary model fails
LITELLM_MODEL_FALLBACK=openai/gpt-4o-mini

# Legacy support (will be used if LITELLM_API_KEY is not set)
OPENAI_API_KEY=sk-proj-...

# Telegram Payments (from @BotFather -> Payments)
PAYMENT_PROVIDER_TOKEN=123456789:TEST:xxxxxx

# YooKassa direct API (required for recurring/auto-renewal payments)
# Get credentials at https://yookassa.ru/my/shop-settings
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Error notifications — comma-separated Telegram user IDs
# Leave empty to disable
ERROR_NOTIFY_TELEGRAM_IDS=
